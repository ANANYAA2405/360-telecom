# Project
PROJECT_NAME=Telecom360
ENVIRONMENT=local

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_ALGORITHM=HS256
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Database
POSTGRES_DB=telecom360
POSTGRES_USER=telecom360
POSTGRES_PASSWORD=telecom360
DATABASE_URL=postgresql+psycopg://telecom360:telecom360@postgres:5432/telecom360

# Redis
REDIS_URL=redis://redis:6379/0
NUMBER_LOCK_TTL_SECONDS=300

# Frontend
VITE_API_BASE_URL=http://localhost:8001/api/v1
VITE_WS_BASE_URL=ws://localhost:8001/ws
